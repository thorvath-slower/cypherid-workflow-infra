{
  "version": "2.0",
  "app_name": "taxon-indexing-eviction-lambda",
  "autogen_policy": false,
  "automatic_layer": false,
  "lambda_memory_size": 1024,
  "lambda_timeout": 900,
  "stages": {
    "dev": {
      "subnet_ids": [
        "${local.taxon_indexing_eviction_subnet_ids[0]}",
        "${local.taxon_indexing_eviction_subnet_ids[1]}"
      ],
      "security_group_ids": [
        "${aws_security_group.taxon_indexing_eviction[0].id}"
      ]
    },
    "staging": {
      "subnet_ids": [
        "${local.taxon_indexing_eviction_subnet_ids[0]}",
        "${local.taxon_indexing_eviction_subnet_ids[1]}"
      ],
      "security_group_ids": [
        "${aws_security_group.taxon_indexing_eviction[0].id}"
      ]
    },
    "prod": {
      "subnet_ids": [
        "${local.taxon_indexing_eviction_subnet_ids[0]}",
        "${local.taxon_indexing_eviction_subnet_ids[1]}"
      ],
      "security_group_ids": [
        "${aws_security_group.taxon_indexing_eviction[0].id}"
      ]
    },
    "sandbox": {
      "subnet_ids": [
        "${local.taxon_indexing_eviction_subnet_ids[0]}",
        "${local.taxon_indexing_eviction_subnet_ids[1]}"
      ],
      "security_group_ids": [
        "${aws_security_group.taxon_indexing_eviction[0].id}"
      ]
    }
  },
  "environment_variables": {}
}