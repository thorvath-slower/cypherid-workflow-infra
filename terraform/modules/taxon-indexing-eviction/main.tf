# VPC attachment for the taxon-indexing-EVICTION Lambda.
#
# Same story as the taxon-indexing worker (modules/taxon-indexing/main.tf): the eviction Lambda
# talks to the VPC-only heatmap OpenSearch domain directly -- chalicelib/es_queries.py builds an
# OpenSearch client from HEATMAP_ES_ADDRESS and runs es().search() + es().delete_by_query() to
# LRU-evict old scored_taxon_counts / pipeline_runs entries. Before this change the eviction Lambda
# ran OUTSIDE the VPC and could not reach that domain, so every eviction run hit `connect
# timeout=120` -- eviction silently never ran and the indices grew unbounded until the domain
# filled. (The worker's VPC fix, #38/#14, covered only modules/taxon-indexing; eviction was missed.)
#
# The Lambda's vpc_config (subnet_ids + security_group_ids) is emitted by chalice into
# chalice.tf.json from the per-stage overrides in lambdas/taxon-indexing-eviction/.chalice/config.json,
# which reference the resources below. Overrides exist only for dev/staging/prod/sandbox; the `test`
# stage (localstack) gets no vpc_config, matching the count = 0 short-circuit here.
#
# NAT/egress: the cloud-env private subnets route egress through a NAT gateway, so the VPC-attached
# Lambda still reaches SSM (HEATMAP_ES_ADDRESS / RDS params), KMS, CloudWatch, RDS (TLS) and the ES
# domain. Attaching to the VPC does NOT sever the Lambda's SSM/API access.

# The webservice ("cloud-env") VPC -- the same VPC the heatmap ES domain lives in.
data "aws_vpc" "webservice_vpc" {
  count = var.deployment_environment == "test" ? 0 : 1

  tags = {
    service = "cloud-env"
    env     = var.deployment_environment
  }
}

# The cloud-env PRIVATE subnets -- where the heatmap ES domain (private_subnets[0..1]) is placed.
data "aws_subnets" "webservice_private_subnets" {
  count = var.deployment_environment == "test" ? 0 : 1

  filter {
    name   = "tag:service"
    values = ["cloud-env"]
  }

  filter {
    name   = "tag:env"
    values = [var.deployment_environment]
  }

  filter {
    name   = "tag:Name"
    values = ["*-private-*"]
  }
}

locals {
  # The two private subnets, matching esdomain.tf which pins the ES domain to
  # private_subnets[0] and private_subnets[1]. Referenced by the chalice vpc_config.
  taxon_indexing_eviction_subnet_ids = try(sort(data.aws_subnets.webservice_private_subnets[0].ids), [])
}

# Dedicated egress security group for the eviction Lambda's ENIs. The ES domain's SG already allows
# the whole VPC CIDR inbound on all ports, so a VPC SG that can egress on 443 is sufficient to reach
# ES over HTTPS. The Lambda also egresses to SSM/KMS/CloudWatch (443, via NAT) and RDS (3306, in-VPC).
# Not created in `test`.
resource "aws_security_group" "taxon_indexing_eviction" {
  # checkov:skip=CKV_AWS_382:Accepted-with-justification. Same rationale as the taxon-indexing
  # worker SG: the Lambda must reach AWS service endpoints (the heatmap OpenSearch domain plus
  # SSM/KMS/CloudWatch over 443, via NAT) whose IPs are not statically known, so HTTPS egress is
  # opened to 0.0.0.0/0. RDS egress is already scoped to the VPC CIDR.
  # checkov:skip=CKV2_AWS_5:False positive. This SG IS attached -- the eviction Lambda's vpc_config
  # (chalice.tf.json, generated by `make package-lambdas`) references
  # aws_security_group.taxon_indexing_eviction[0].id, but checkov's graph does not trace the SG id
  # through chalice's interpolated string into the aws_lambda_function vpc_config block.
  count = var.deployment_environment == "test" ? 0 : 1

  # NOTE: no apostrophe -- AWS SG descriptions reject "'" (allowed set is a-zA-Z0-9. _-:/()#,@[]+=&;{}!$*).
  name        = "taxon-indexing-eviction-lambda-${var.deployment_environment}"
  description = "Egress for the taxon-indexing eviction Lambda VPC ENIs (heatmap ES over 443, RDS over 3306)."
  vpc_id      = data.aws_vpc.webservice_vpc[0].id

  egress {
    description = "HTTPS to the heatmap OpenSearch domain and to AWS APIs (SSM/KMS/CloudWatch) via NAT"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    description = "MySQL/Aurora to the RDS instance inside the VPC"
    from_port   = 3306
    to_port     = 3306
    protocol    = "tcp"
    cidr_blocks = [data.aws_vpc.webservice_vpc[0].cidr_block]
  }
}
