# VPC attachment for the taxon-indexing Lambda.
#
# The heatmap OpenSearch domain (cypherid-web-infra .../heatmap-optimization/esdomain.tf,
# module aws-elasticsearch-v0.199.1) is VPC-only: it is placed on the cloud-env
# private_subnets[0..1] and its security group allows ingress from the whole VPC CIDR
# (ingress_cidrs = vpc_cidr_block). Before this change the Lambda ran OUTSIDE the VPC and
# could not reach that domain, so every index_taxons invocation hit `connect timeout=120`
# to vpc-czid-<env>-heatmap-es-*.es.amazonaws.com and heatmaps broke in dev + staging.
#
# The Lambda's vpc_config (subnet_ids + security_group_ids) is emitted by chalice into
# chalice.tf.json from the per-stage overrides in lambdas/taxon-indexing/.chalice/config.json,
# which reference the resources below. Those overrides exist only for dev/staging/prod/sandbox;
# the `test` stage (localstack) gets no vpc_config, matching the count = 0 short-circuit here.
#
# NAT/egress note (the make-or-break for a VPC-attached Lambda): the cloud-env private
# subnets route egress through a NAT gateway (aws-env-v4.0.0/vpc.tf: enable_nat_gateway = true,
# single_nat_gateway = true in every env). So the Lambda, once in these subnets, still reaches
# SSM (HEATMAP_ES_ADDRESS / RDS_ADDRESS / db_password params), KMS, CloudWatch, RDS (TLS) and
# the ES domain. Attaching to the VPC does NOT sever the Lambda's SSM/API access.

# The webservice ("cloud-env") VPC — the same VPC the heatmap ES domain lives in.
# Short-circuited in `test` (localstack) exactly like data.aws_vpc.webservice_vpc in
# index-generation.tf.
data "aws_vpc" "webservice_vpc" {
  count = var.deployment_environment == "test" ? 0 : 1

  tags = {
    service = "cloud-env"
    env     = var.deployment_environment
  }
}

# The cloud-env PRIVATE subnets — where the heatmap ES domain (private_subnets[0..1])
# is placed. index-generation.tf uses the *-public-* equivalent for its public Batch tier;
# here we need the private subnets so the Lambda lands alongside the VPC-only ES domain.
data "aws_subnets" "webservice_private_subnets" {
  count = var.deployment_environment == "test" ? 0 : 1

  filter {
    name   = "tag:service"
    values = ["cloud-env"]
  }

  filter {
    name   = "tag:env"
    values = [var.deployment_environment]
  }

  filter {
    name   = "tag:Name"
    values = ["*-private-*"]
  }
}

locals {
  # The two private subnets, matching esdomain.tf which pins the ES domain to
  # private_subnets[0] and private_subnets[1]. Referenced by the chalice vpc_config.
  taxon_indexing_subnet_ids = try(sort(data.aws_subnets.webservice_private_subnets[0].ids), [])
}

# Dedicated egress security group for the Lambda's ENIs. The ES domain's SG already allows
# the whole VPC CIDR inbound on all ports (ingress_rules = ["all-all"], ingress_cidrs =
# vpc_cidr_block), so a VPC SG that can egress on 443 is sufficient to reach ES over HTTPS.
# The Lambda also egresses to SSM/KMS/CloudWatch (443, via NAT) and RDS (3306, in-VPC);
# 443 + 3306 cover those. Not created in `test`.
resource "aws_security_group" "taxon_indexing" {
  # checkov:skip=CKV_AWS_382:Accepted-with-justification. Same rationale as
  # aws_security_group.index_generation: the Lambda must reach AWS service endpoints (the heatmap
  # OpenSearch domain plus SSM/KMS/CloudWatch over 443, via NAT) whose IPs are not statically
  # known, so HTTPS egress is opened to 0.0.0.0/0. RDS egress is already scoped to the VPC CIDR.
  # Egress becomes fully scopable via the VPC endpoints architecture (CZID-352,
  # design: VPC-ENDPOINTS-ARCHITECTURE-2026-06-29.md).
  # checkov:skip=CKV2_AWS_5:False positive. This SG IS attached — the taxon-indexing Lambda's
  # vpc_config (chalice.tf.json, generated by `make package-lambdas`) references
  # aws_security_group.taxon_indexing[0].id, but checkov's graph does not trace the SG id through
  # chalice's interpolated string into the aws_lambda_function.index_taxons vpc_config block.
  count = var.deployment_environment == "test" ? 0 : 1

  name = "taxon-indexing-lambda-${var.deployment_environment}"
  # NOTE: no apostrophe -- AWS SG descriptions reject "'" (allowed set is a-zA-Z0-9. _-:/()#,@[]+=&;{}!$*).
  description = "Egress for the taxon-indexing Lambda VPC ENIs (heatmap ES over 443, RDS over 3306)."
  vpc_id      = data.aws_vpc.webservice_vpc[0].id

  egress {
    description = "HTTPS to the heatmap OpenSearch domain and to AWS APIs (SSM/KMS/CloudWatch) via NAT"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    description = "MySQL/Aurora to the RDS instance inside the VPC"
    from_port   = 3306
    to_port     = 3306
    protocol    = "tcp"
    cidr_blocks = [data.aws_vpc.webservice_vpc[0].cidr_block]
  }
}
